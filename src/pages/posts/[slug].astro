---
import Layout from '../../layouts/Layout.astro';
import { SITE_TITLE, SITE_URL, AUTHOR_NAME } from '../../lib/consts';
import { formatDateLong, toISODate } from '../../lib/date';
import { getPublishedPosts } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const isoDate = toISODate(post.data.date);
const description = post.data.description ?? post.data.html
  ?.replace(/<[^>]+>/g, '')
  .replace(/\s+/g, ' ')
  .trim()
  .slice(0, 160) ?? '';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  datePublished: isoDate,
  author: { "@type": "Person", name: AUTHOR_NAME },
};

---

<Layout
  title={`${post.data.title} — ${SITE_TITLE}`}
  description={description}
  ogImage={`${SITE_URL}/og/${post.id}.png`}
  preloadAllFonts
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <a href="/" class="back-link mb-8 inline-block focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2">
<span aria-hidden="true" style="font-family: Georgia, serif;">&larr;</span> back
  </a>

  <article class="max-w-none">
    <h1 class="text-3xl font-medium mb-4">{post.data.title}</h1>
    <time datetime={isoDate} class="text-sm mb-8 block">
      {formatDateLong(post.data.date)}
    </time>
    <div class="prose prose-lg md:prose-xl max-w-none" set:html={post.data.html} />
  </article>
</Layout>
