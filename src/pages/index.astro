---
import Layout from '../layouts/Layout.astro';
import { SITE_URL, SITE_TITLE } from '../lib/consts';
import { formatDate, toISODate } from '../lib/date';
import { getPublishedPosts } from '../lib/posts';

const posts = await getPublishedPosts();

---

<Layout ogImage={`${SITE_URL}/og.png`}>
  <header class="mb-1">
    <h1 class="text-3xl md:text-4xl font-medium tracking-tight mb-8 pl-1 -ml-1">
      {SITE_TITLE}
    </h1>
    <hr />
  </header>

  <nav aria-label="Blog posts" class="nav-left-breakout mt-10">
    <ul class="flex flex-col">
      {posts.map((post) => (
        <li class="flex justify-between items-end gap-6 mb-10">
          <h2 class="font-['Newsreader'] font-black text-[clamp(2rem,6vw,3.5rem)] leading-[.92] tracking-[-0.04em]">
            <a href={`/posts/${post.id}`} class="hover:italic hover:font-light transition-none">
              {post.data.title}
            </a>
          </h2>
          <time datetime={toISODate(post.data.date)} class="font-['Newsreader'] text-sm whitespace-nowrap pb-1 shrink-0">
            {formatDate(post.data.date)}
          </time>
        </li>
      ))}
    </ul>
  </nav>

</Layout>
