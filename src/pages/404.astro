---
import Layout from '../layouts/Layout.astro';
import { SITE_TITLE } from '../lib/consts';
---

<Layout title={`not found — ${SITE_TITLE}`}>
  <div class="flex flex-col items-center justify-center min-h-[50vh] text-center">
    <h1 class="text-3xl font-medium mb-4">
      not found
    </h1>
    <p class="mb-8" style="color: var(--color-muted);">
      you've reached the edge of my thoughts.
    </p>
    <a
      href="/"
      class="back-link"
    >
      <span aria-hidden="true" style="font-family: Georgia, serif;">&larr;</span> back home
    </a>
  </div>
</Layout>
